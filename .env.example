# ──────────────────────────────────────────────────────────────────────
# Last Mile Health RAG — Master Environment Variables Example (.env.example)
# ──────────────────────────────────────────────────────────────────────
# Instructions: Copy this file to '.env' at the root and fill in your keys.
# DO NOT commit the '.env' file or any active keys to version control.
# ──────────────────────────────────────────────────────────────────────

# ── App Configuration ──────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info
BACKEND_URL=http://backend:6100

# ── Relational Database (PostgreSQL + pgvector) ──────────
# Used by both Docker Compose and the FastAPI application
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@relational_db:5432/postgres

# ── LLM / Embedding Providers ──────────────────────────
#
# HOW THIS SYSTEM USES API KEYS
# -----------------------------
# Keys are read from the environment ONLY (`os.getenv`). They are never written to the
# database, never logged, never returned by an API response, and never sent to the browser.
# The frontend has no key of any kind: it talks only to this backend, which owns every
# provider call. That is why `frontend/.env.local.example` contains just a base URL.
#
# API KEYS BY AGENTIC TASK  (this is the map an assessor needs)
# ------------------------------------------------------------
# Each agent in the RAG pipeline chooses its provider from the cheapest CONFIGURED key that
# suits its task (see backend/app/core/model_router.py). One exception: the JudgeAgent is
# PINNED to Anthropic Opus and never cost-routed (a grader must be stable across runs).
#
#   Agent / task            Key it uses (in cost order)        Model (local default)     Why
#   --------------------    -------------------------------    ----------------------    -----------------------------
#   Answer generation       GEMINI -> OPENAI -> ANTHROPIC      gemini-3.1-flash-lite     Cheapest capable model; answer
#     (the /chat brain)                                                                  quality is the product.
#   Embeddings              GEMINI -> OPENAI -> VOYAGE         gemini-embedding-001      Powers semantic search. MUST
#     (vector search)                                          (1536-dim)                match EMBEDDING_DIM.
#   Fast/mechanical tasks   GEMINI -> OPENAI -> ANTHROPIC      gemini-3.1-flash-lite     Summaries, query expansion,
#     (summarize/expand)                                                                 planning: cheapest small model.
#   Ingestion planning      ANTHROPIC (else deterministic)     claude-* (agent loop)     Structure/OCR judgement. Falls
#     (ingestion agent)                                                                  back to a deterministic per-page
#                                                                                        path when no Anthropic key.
#   JudgeAgent  (PINNED)    ANTHROPIC ONLY                     claude-opus-4-8           Reproducible grader. NOT routed
#     (grading / gold eval)   (else a loud fallback)                                     for cost. A non-Opus judge is
#                                                                                        logged and its scores are marked
#                                                                                        not-comparable to an Opus baseline.
#
# WHAT HAPPENS WITH NO KEY AT ALL
# -------------------------------
# The system degrades rather than crashing, and SAYS SO. /chat returns a `model_status` the
# UI renders as a plain-language notice, and the degraded choice is written to the audit log
# (agent_trace_log). The degraded path is NOT the product, so a reviewer judging answer
# quality must set at least a generation key and an embedding key:
#   - No generation key  -> answers are EXTRACTED from your documents, not written. A broad
#                           question ("what are the main instructions?") returns no-answer.
#   - No embedding key   -> hash-based vectors; SEMANTIC SEARCH IS EFFECTIVELY OFF and only
#                           the lexical half of hybrid retrieval works.
#   - No Anthropic key   -> the JudgeAgent grades with a keyword heuristic, so gold scores
#                           reflect the heuristic, not an LLM judge. Its metadata records this.
#
# PROVIDER IS CHOSEN FROM THE MODEL NAME + CONFIGURED KEYS, NOT HARDCODED
# ----------------------------------------------------------------------
#   MODEL_ROUTING=auto    -> each task picks the cheapest configured provider suited to it.
#   MODEL_ROUTING=manual  -> honor GENERATION_MODEL_PRIMARY / _FAST exactly as pinned below.
#   gemini-*  needs GEMINI_API_KEY    |  claude-*  needs ANTHROPIC_API_KEY
#   gpt-*     needs OPENAI_API_KEY    |  text-embedding-*  needs OPENAI_API_KEY
#   voyage-*  needs VOYAGE_API_KEY
#
# CHANGING THE EMBEDDING MODEL IS A RE-INDEX, NOT A CONFIG FLIP.
# The pgvector column is fixed-width at EMBEDDING_DIM. `gemini-embedding-001` is natively
# 3072-dim but supports Matryoshka truncation, so it is requested at exactly 1536 to fit the
# existing column. A model whose dimension cannot be set would require a migration and a full
# re-ingest. The semantic cache is scoped by embedding model, so vectors from two different
# models are never compared.
#
# NOTE: model availability differs per key. `gemini-2.5-flash` is listed by the API but 404s
# for newly issued keys ("no longer available to new users"). Verify with
# `GET /v1beta/models` before pinning a model.
#
# PLACEHOLDER SAFETY
# ------------------
# The values below are placeholders and are detected as such (`_is_real_key`). A placeholder
# is treated as "no key" and selects the local fallback, so a copied-but-unedited .env
# degrades cleanly instead of 401-ing on every chat turn. Do not "fix" that by shortening
# the placeholder to something that looks real.
#
# PRODUCTION
# ----------
# Do NOT ship a .env to production. Inject these from AWS Secrets Manager / SSM at task
# start, rotate on a schedule, and scope each key to least privilege. See DEPLOYMENT.md
# ("Secrets and API key management") for the full posture, including why the backend is the
# only process that ever holds a provider key.
#
ANTHROPIC_API_KEY=your-anthropic-api-key-here                # JudgeAgent (pinned Opus) + generation/ingestion when routed
OPENAI_API_KEY=your-openai-api-key-here                      # Embeddings -> semantic search
GEMINI_API_KEY=your-gemini-api-key-here                      # Generation + embeddings (local default provider)
VOYAGE_API_KEY=your-voyage-api-key-here                      # Optional embedding alternative
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
GENERATION_MODEL_PRIMARY=claude-sonnet-5
GENERATION_MODEL_FAST=claude-haiku-4-5
# Optional - unset defaults to local cross-encoder
RERANK_PROVIDER=
# Verify provider pricing at deploy time.
MODEL_PRICING_JSON={"claude-sonnet-5":{"input_per_mtok":3.0,"output_per_mtok":15.0},"claude-haiku-4-5":{"input_per_mtok":0.8,"output_per_mtok":4.0}}

# ── Local Reranker ─────────────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Chunking & Ingestion Strategy ──────────────────────
CHUNK_SIZE_TOKENS=480
CHUNK_OVERLAP_RATIO=0.15
STRUCTURE_AWARE_CHUNKING=true

# ── PDF Upload Limits ──────────────────────────────────
MAX_PDF_SIZE_MB=65
MAX_PDF_PAGES=700
ALLOWED_MIME_TYPES=application/pdf
REQUEST_BODY_SIZE_LIMIT_BYTES=75497472

# ── Table/Figure Structure Detection & Page Images ─────
TABLE_DETECTION_METHOD=pdfplumber            # pdfplumber | heuristic_grid
PAGE_IMAGE_DPI=200
PAGE_IMAGE_STORAGE_BACKEND=local             # local | s3
OCR_ENGINE=tesseract
OCR_TEXT_YIELD_THRESHOLD=0.15                # Below this ratio, page is treated as scanned OCR fallback

# ── Multi-Agent Ingestion & Retrieval ──────────────────
AGENT_MODEL=claude-sonnet-5                  # Model for agent reasoning turns
RETRIEVAL_AGENT_CONFIDENCE_THRESHOLD=0.55    # sigmoid relevance (0-1), below this triggers query expansion
RETRIEVAL_AGENT_MAX_ITERATIONS=3
INGESTION_AGENT_MAX_ITERATIONS_HARD_CEILING=320
AGENT_TRACE_LOGGING_ENABLED=true

# ── Retrieval Parameters ──────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
HYBRID_SEARCH_ENABLED=true
HYBRID_FUSION_METHOD=rrf
RRF_K=60
HNSW_M=16
HNSW_EF_CONSTRUCTION=64
HNSW_EF_SEARCH=40
GROUNDING_TSVECTOR_CONFIG=english            # PostgreSQL full-text config for lexical retrieval

# ── Caching Configurations ──────────────────────────────
CACHE_BACKEND=postgres                       # postgres | redis
REDIS_URL=redis://redis:6379/0               # Required if CACHE_BACKEND=redis
EXACT_CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_ROWS=5000
PROMPT_CACHING_ENABLED=true

# ── Conversation Context & Token Management ────────────
CONVERSATION_WINDOW_TURNS=6
CONVERSATION_SUMMARY_TRIGGER_TOKENS=2000
MAX_OUTPUT_TOKENS_CHAT=500
MAX_OUTPUT_TOKENS_SUMMARY=200

# ── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_PER_SESSION_PER_HOUR=30
RATE_LIMIT_WINDOW_SECONDS=3600
RATE_LIMIT_PER_IP_PER_HOUR=100

# ── Security Configurations ────────────────────────────
JWT_SECRET=your-jwt-signing-secret-here
SESSION_TOKEN_EXPIRY_MINUTES=60
ANONYMOUS_CHAT_ALLOWED=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CHAINLIT_AUTH_SECRET=your-chainlit-secret-here
CHAINLIT_BACKEND_AUTH_TOKEN=                 # Optional bearer token if ANONYMOUS_CHAT_ALLOWED=false
CHAINLIT_BACKEND_TIMEOUT_SECONDS=30

# ── Storage Configurations ─────────────────────────────
UPLOAD_STORAGE_BACKEND=local                 # local | s3
S3_BUCKET_NAME=your-s3-bucket-name           # Used by S3 storage branches via IAM/task role credentials
# Optional override for uploaded PDFs
S3_DOCUMENT_BUCKET=
# Optional override for rasterized page images
S3_PAGE_IMAGE_BUCKET=
AWS_REGION=us-east-1

# ── Scheduling ─────────────────────────────────────────
ENABLE_SCHEDULED_JOBS=true
CACHE_EVICTION_CRON=0 * * * *
SCHEDULER_LEADER_LOCK_KEY=91537              # Postgres advisory-lock namespace for singleton scheduled jobs
GRADING_JOB_CRON=0 2 * * *                   # Nightly retrospective response grading/anomaly pass
RESPONSE_GRADING_SAMPLE_SIZE=50              # Max judged live responses per grading run
ANOMALY_DETECTION_ZSCORE_THRESHOLD=3.0
ANOMALY_DETECTION_BASELINE_LOOKBACK_DAYS=14

# ── Grounding / Judge Agent ────────────────────────────
GROUNDING_NUMERIC_CHECK_ENABLED=true
GROUNDING_NUMERIC_TOLERANCE=0.0              # Output numeric claims are exact-match only; do not loosen for clinical dosing
JUDGE_MODEL=claude-haiku-4-5
JUDGE_TEMPERATURE=0.0
JUDGE_RUBRIC_VERSION=1

# ── Gold-Standard Evaluation ───────────────────────────
GOLD_CORPUS_DIR=./gold_standard/corpus/files
GOLD_QUESTIONS_PATH=./gold_standard/questions.yaml
GOLD_RUBRIC_PATH=./gold_standard/rubric.yaml
# Optional override; defaults to JUDGE_MODEL
GOLD_EVAL_JUDGE_MODEL=
GOLD_EVAL_CONCURRENCY=2                         # Bound /chat calls during manual/scheduled gold runs
GOLD_EVAL_REPORT_PATH=./gold_standard/gold_eval_report.md
GOLD_EVAL_CRON=0 3 * * *
GOLD_EVAL_SAMPLE_SIZE=
GOLD_EVAL_BASELINE_LOOKBACK_RUNS=14
GOLD_EVAL_MIN_OVERALL_SCORE=90.0
GOLD_EVAL_REGRESSION_POINTS=5.0
GOLD_EVAL_DEVIATION_ABS_DROP=5.0
GOLD_EVAL_DEVIATION_ZSCORE=3.0
GOLD_EVAL_ALERT_ON_VERSION_CHANGE=false
GOLD_CHAT_URL=http://localhost:6100/api/v1/chat
GOLD_CHAT_AUTH=

# Frontend browser-visible variables live in frontend/.env.local.example:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:6100/api/v1
