# ──────────────────────────────────────────────────────────────────────
# Last Mile Health RAG — Master Environment Variables Example (.env.example)
# ──────────────────────────────────────────────────────────────────────
# Instructions: Copy this file to '.env' at the root and fill in your keys.
# DO NOT commit the '.env' file or any active keys to version control.
# ──────────────────────────────────────────────────────────────────────

# ── App Configuration ──────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info
BACKEND_URL=http://backend:6100

# ── Relational Database (PostgreSQL + pgvector) ──────────
# Used by both Docker Compose and the FastAPI application
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@relational_db:5432/postgres

# ── LLM / Embedding Providers ──────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here                      # Used for OpenAI embeddings
GEMINI_API_KEY=your-gemini-api-key-here                      # Google Gemini API Key for fast/flexible models
OPUS_API_KEY=your-opus-api-key-here                          # Dedicated Claude Opus API Key for high-reasoning evaluation
VOYAGE_API_KEY=your-voyage-api-key-here                      # Optional — paired with Claude/Voyage
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
GENERATION_MODEL_PRIMARY=claude-sonnet-5
GENERATION_MODEL_FAST=claude-haiku-4-5
EVALUATION_MODEL_OPUS=claude-opus-3                          # Dedicated Claude Opus model for Evaluation & Grading Agent
RERANK_PROVIDER=                             # Optional - unset defaults to local cross-encoder

# ── Local Reranker ─────────────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Chunking & Ingestion Strategy ──────────────────────
CHUNK_SIZE_TOKENS=480
CHUNK_OVERLAP_RATIO=0.15
STRUCTURE_AWARE_CHUNKING=true

# ── PDF Upload Limits ──────────────────────────────────
MAX_PDF_SIZE_MB=20
MAX_PDF_PAGES=300
ALLOWED_MIME_TYPES=application/pdf

# ── Table/Figure Structure Detection & Page Images ─────
TABLE_DETECTION_METHOD=pdfplumber            # pdfplumber | heuristic_grid
PAGE_IMAGE_DPI=200
PAGE_IMAGE_STORAGE_BACKEND=local             # local | s3
OCR_ENGINE=tesseract
OCR_TEXT_YIELD_THRESHOLD=0.15                # Below this ratio, page is treated as scanned OCR fallback

# ── Multi-Agent Ingestion & Retrieval ──────────────────
AGENT_MODEL=claude-sonnet-5                  # Model for agent reasoning turns
RETRIEVAL_AGENT_CONFIDENCE_THRESHOLD=0.55    # sigmoid relevance (0-1), below this triggers query expansion
RETRIEVAL_AGENT_MAX_ITERATIONS=3
INGESTION_AGENT_MAX_ITERATIONS_HARD_CEILING=320
AGENT_TRACE_LOGGING_ENABLED=true

# ── Retrieval Parameters ──────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
HYBRID_SEARCH_ENABLED=true
HYBRID_FUSION_METHOD=rrf
RRF_K=60
HNSW_M=16
HNSW_EF_CONSTRUCTION=64
HNSW_EF_SEARCH=40

# ── Caching Configurations ──────────────────────────────
CACHE_BACKEND=postgres                       # postgres | redis
REDIS_URL=redis://redis:6379/0               # Required if CACHE_BACKEND=redis
EXACT_CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_ROWS=5000
PROMPT_CACHING_ENABLED=true

# ── Conversation Context & Token Management ────────────
CONVERSATION_WINDOW_TURNS=6
CONVERSATION_SUMMARY_TRIGGER_TOKENS=2000
MAX_OUTPUT_TOKENS_CHAT=500
MAX_OUTPUT_TOKENS_SUMMARY=200

# ── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_PER_SESSION_PER_HOUR=30
RATE_LIMIT_WINDOW_SECONDS=3600
RATE_LIMIT_PER_IP_PER_HOUR=100

# ── Security Configurations ────────────────────────────
JWT_SECRET=your-jwt-signing-secret-here
SESSION_TOKEN_EXPIRY_MINUTES=60
ANONYMOUS_CHAT_ALLOWED=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CHAINLIT_AUTH_SECRET=your-chainlit-secret-here

# ── Storage Configurations ─────────────────────────────
UPLOAD_STORAGE_BACKEND=local                 # local | s3
S3_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=us-east-1

# ── Scheduling ─────────────────────────────────────────
ENABLE_SCHEDULED_JOBS=true
CACHE_EVICTION_CRON=0 * * * *
